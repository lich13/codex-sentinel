{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Sentinel",
  "version": "0.1.0",
  "identifier": "local.codex-sentinel",
  "build": {
    "beforeBuildCommand": "npm run build:ui",
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "ui-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Sentinel",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-template.png",
      "iconAsTemplate": true,
      "showMenuOnLeftClick": false,
      "tooltip": "Codex Sentinel"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Codex Sentinel",
    "longDescription": "A macOS dashboard and Telegram controller for monitoring Codex and recovering from transient failures.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist",
      "signingIdentity": "-"
    }
  }
}
