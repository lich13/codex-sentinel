{
  "name": "codex-sentinel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:ui": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:ui": "vite build",
    "check": "cargo check",
    "test": "cargo test",
    "ci": "cargo fmt -- --check && cargo test && npm run build:ui",
    "probe:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-probe.ps1",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows.ps1",
    "tauri": "tauri",
    "tauri:build": "npm run tauri:build:mac:arm64",
    "tauri:build:mac:arm64": "tauri build --bundles dmg --target aarch64-apple-darwin",
    "tauri:build:windows": "tauri build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
